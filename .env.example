# TradingAI Intelligence - Plantilla de Entorno
# -----------------------------------------------------------------------------
# INSTRUCCIONES:
# 1. Copia este archivo como '.env'
# 2. Rellena tus credenciales privadas (se mantienen fuera del repo público)
# -----------------------------------------------------------------------------

# --- MODO DE OPERACIÓN ---
# False = Real Market (Nansen API) | True = Mock/Simulación (Dato simulado + Exchange Testnet)
DEBUG_MODE=True
# Frecuencia del bucle principal
POLLING_INTERVAL_MINUTES=15

# --- NANSEN API (Análisis On-Chain) ---
# Consigue tu key en https://www.nansen.ai/
NANSEN_API_KEY="TU_NANSEN_KEY_AQUI"

# --- EXCHANGE: BINANCE (Testnet o Mainnet) ---
# Nota: Si estas keys están rellenas, el bot priorizará Binance.
BINANCE_API_KEY="TU_BINANCE_API_KEY"
BINANCE_SECRET="TU_BINANCE_SECRET"

# --- EXCHANGE: MEXC (Alternativo) ---
# Nota: Se usará solo si las de Binance anteriores están vacías.
MEXC_API_KEY="TU_MEXC_API_KEY"
MEXC_SECRET="TU_MEXC_SECRET"

# --- NOTIFICACIONES TELEGRAM ---
# Consigue el Token via @BotFather y ID via @userinfobot
TELEGRAM_TOKEN="TU_BOT_TOKEN"
TELEGRAM_CHAT_ID="TU_CHAT_ID"

# --- INTELIGENCIA ARTIFICIAL (GEMINI) ---
# Google GEMINI API - Obten tu key en: https://aistudio.google.com/apikey
GEMINI_API_KEY="TU_GEMINI_KEY"
# Modelos sugeridos: 'gemini-2.0-flash' o 'gemini-1.5-pro'
GEMINI_MODEL="models/gemini-2.0-flash"

# --- FILTROS DE RIESGO ---
# Entrada mínima para considerar señal (USD)
MIN_INFLOW_LIMIT=25000.0
# Objetivos automáticos
TAKE_PROFIT_PCT=5.0
STOP_LOSS_PCT=-2.0
